{"success":true,"data":{"config":{"language":"en-US","site_name":"MyVPS-PaaS","custom_code":"\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n\u003chead\u003e\n  \u003cmeta charset=\"UTF-8\"\u003e\n  \u003cmeta name=\"abuseipdb-verification\" content=\"zseczkct\" /\u003e\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\n  \u003ctitle\u003eNezha Monitoring\u003c/title\u003e\n  \u003cscript src=\"https://cdn.jsdelivr.net/npm/disable-devtool@latest/disable-devtool.min.js\"\u003e\u003c/script\u003e\n  \u003cscript\u003e\n    DisableDevtool({\n        interval: 500,\n        url: 'https://protected.milik-fukada.eu.org/?edge.nyc.mn', \n        clearLog: true, \n        disableMenu: true,\n        debuggerMessage: 'Stop!',\n        isDevIframe: true\n    });\n  \u003c/script\u003e\n  \u003cstyle\u003e\n    /* Container for fixed bottom-left badge */\n    .fixed-bottom-badge {\n      position: fixed;\n      bottom: 15px;\n      left: 15px;\n      z-index: 1000;\n    }\n\n    /* --- DEFAULT STYLE (LIGHT THEME) --- */\n    .fixed-bottom-badge a {\n      display: flex;\n      align-items: center;\n      background-color: rgba(249, 250, 251, 0.75);\n      backdrop-filter: blur(10px);\n      -webkit-backdrop-filter: blur(10px);\n      padding: 8px 12px;\n      border-radius: 12px;\n      text-decoration: none;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);\n      transition: background-color 0.3s ease;\n    }\n\n    .fixed-bottom-badge img {\n      width: 161px;\n      display: block;\n      filter: none;\n      transition: filter 0.3s ease;\n    }\n\n    /* --- DARK MODE OVERRIDES --- */\n    html.dark .fixed-bottom-badge a {\n      background-color: rgba(26, 27, 30, 0.75);\n    }\n\n    html.dark .fixed-bottom-badge img {\n      filter: brightness(0) invert(1);\n    }\n\n    /* ======================================================================= */\n    /* --- HIDE NEZHA-DASH THEME WATERMARK (SAFE MODE) ---                     */\n    /* ======================================================================= */\n    a[href*=\"hamster1963/nezha-dash\"] {\n      display: none !important;\n    }\n\n    /* ======================================================================= */\n    /* --- TYPING EFFECT CURSOR ANIMATION ---                                  */\n    /* ======================================================================= */\n    .typing-cursor {\n      display: inline-block;\n      width: 2.5px;\n      height: 1.1em;\n      background-color: currentColor;\n      margin-left: 3px;\n      vertical-align: text-bottom;\n      animation: blink 1s step-end infinite;\n      border-radius: 2px;\n    }\n\n    @keyframes blink {\n      0%, 100% { opacity: 1; }\n      50% { opacity: 0; }\n    }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cdiv class=\"fixed-bottom-badge\"\u003e\n    \u003ca href=\"https://www.abuseipdb.com/user/229325\" title=\"AbuseIPDB is an IP address blacklist for webmasters and sysadmins to report IP addresses engaging in abusive behavior on their networks\"\u003e\n      \u003cimg src=\"https://www.abuseipdb.com/contributor/229325.svg\" alt=\"AbuseIPDB Contributor Badge\"\u003e\n    \u003c/a\u003e\n  \u003c/div\u003e\n  \u003cscript\u003e\n    // =========================================================\n    // 1. NEZHA THEME CONFIGURATION\n    // =========================================================\n    window.CustomBackgroundImage = 'https://picsum.photos/1920/1080';\n    window.CustomMobileBackgroundImage = 'https://picsum.photos/1080/1920';\n    window.CustomLogo = '';\n    window.CustomDesc = 'My PaaS/VPS Global Distribution Monitoring';\n    window.ShowNetTransfer = true;\n    window.ForceShowMap = true;\n    window.DisableAnimatedMan = false;\n    window.CustomIllustration = 'https://null.lucazchad.workers.dev/main';\n    window.FixedTopServerName = true;\n    window.CustomLinks = '[{\"link\":\"https://t.me/llvanoII\",\"name\":\"Telegram\"}]';\n    window.ForceTheme = 'dark';\n\n    // =========================================================\n    // 2. TYPING EFFECT MESSAGES \u0026 LOGIC\n    // =========================================================\n    const messages = [\n        \"👋 Hello World\", \n        \"🚀 Welcome to my Server Monitoring\",\n        \"⚡ Powered by Nezha\",\n        \"\u003e_ CF RATELIMIT + CUSTOM WAF + CACHED\",\n        \"🖥️ System Status: Online\",\n        \"☕ Have a nice day!\",\n        \"🛡️ Security Level: High\"\n    ];\n\n    let msgIndex = 0;\n    let charIndex = 0;\n    let isDeleting = false;\n\n    // Fungsi Utama Efek Mengetik (Sudah Diperbaiki untuk EMOJI)\n    function typeWriterLoop() {\n        const typingEl = document.getElementById('typing-text');\n        \n        if (!typingEl) {\n            setTimeout(typeWriterLoop, 200);\n            return;\n        }\n\n        // Ubah string jadi array untuk mencegah emoji (surrogate pairs) terbelah jadi \n        const currentMsgArray = [...messages[msgIndex]];\n\n        if (isDeleting) {\n            typingEl.textContent = currentMsgArray.slice(0, charIndex - 1).join('');\n            charIndex--;\n        } else {\n            typingEl.textContent = currentMsgArray.slice(0, charIndex + 1).join('');\n            charIndex++;\n        }\n\n        let speed = isDeleting ? 30 : 70;\n\n        if (!isDeleting \u0026\u0026 charIndex === currentMsgArray.length) {\n            speed = 3000; // Pause saat teks utuh\n            isDeleting = true;\n        } else if (isDeleting \u0026\u0026 charIndex === 0) {\n            isDeleting = false;\n            msgIndex = (msgIndex + 1) % messages.length; \n            speed = 500; // Jeda sebelum ngetik ulang\n        }\n\n        setTimeout(typeWriterLoop, speed);\n    }\n\n    typeWriterLoop();\n\n    // =========================================================\n    // 3. INJECTOR / TEXT REPLACER (Memaksa hapus \"Overview\")\n    // =========================================================\n    function injectTypingElement() {\n        var walker = document.createTreeWalker(\n            document.body, \n            NodeFilter.SHOW_TEXT, \n            null, \n            false\n        );\n\n        var node;\n        while (node = walker.nextNode()) {\n            let val = node.nodeValue;\n            let parent = node.parentNode;\n\n            // Hindari memodifikasi menu Link/Sidebar, Tag script, atau Title window\n            if (parent \u0026\u0026 ['TITLE', 'A', 'SCRIPT', 'STYLE'].includes(parent.tagName)) {\n                continue;\n            }\n\n            // Hapus teks \"Theme by\"\n            if (val.includes('Theme by')) {\n                node.nodeValue = val.replace(/Theme by/g, '');\n            }\n\n            // Hapus icon tangan asli bawaan Nezha\n            if (val.includes('👋')) {\n                node.nodeValue = val.replace(/👋/g, '');\n            }\n\n            // Target Tulisan \"Overview\"\n            if (val.includes('Overview')) {\n                \n                // SELALU hapus tulisan \"Overview\" secara paksa.\n                node.nodeValue = val.replace(/Overview/g, '').trim();\n                \n                // Cek agar kita tidak memasukkan elemen ketikan dobel\n                if (parent \u0026\u0026 !parent.querySelector('#typing-text')) {\n                    \n                    let typerSpan = document.createElement('span');\n                    typerSpan.id = 'typing-text';\n                    \n                    let cursorSpan = document.createElement('span');\n                    cursorSpan.className = 'typing-cursor';\n                    \n                    // Masukkan ke tempat Overview aslinya berada\n                    if (node.nextSibling) {\n                        parent.insertBefore(typerSpan, node.nextSibling);\n                        parent.insertBefore(cursorSpan, typerSpan.nextSibling);\n                    } else {\n                        parent.appendChild(typerSpan);\n                        parent.appendChild(cursorSpan);\n                    }\n                }\n            }\n        }\n    }\n\n    // Jalankan injector setiap 200ms\n    setInterval(injectTypingElement, 200);\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e","custom_code_dashboard":"\u003c!-- DISABLE DEVTOOL (Mencegah Klik Kanan, F12, \u0026 Inspect Element) --\u003e\n\u003cscript disable-devtool-auto src=\"https://cdn.jsdelivr.net/npm/disable-devtool\"\u003e\u003c/script\u003e\n\n\u003cscript\u003e\n  window.DisableAnimatedMan = true; \n\u003c/script\u003e\n\u003clink href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700\u0026display=swap\" rel=\"stylesheet\"\u003e\n\n\u003cstyle\u003e\n  body, .ant-typography, .ant-menu, .ant-btn, .ant-card, .ant-table {\n    font-family: 'Plus Jakarta Sans', sans-serif !important;\n  }\n  ::-webkit-scrollbar { width: 8px; height: 8px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.15); border-radius: 10px; }\n\n  .ui.green.label, .ant-badge-status-success { box-shadow: 0 0 8px rgba(34, 197, 94, 0.6); }\n  .ui.red.label, .ant-badge-status-error { box-shadow: 0 0 8px rgba(239, 68, 68, 0.6); }\n\n  /* Mencegah Tombol Home Hilang */\n  .ant-layout-header { position: relative !important; z-index: 9999 !important; }\n  .ant-layout-header .logo, .ant-layout-header a, .ant-menu-item { color: #ffffff !important; opacity: 1 !important; visibility: visible !important; }\n\n  /* Background Canvas */\n  #canvas { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -9999; pointer-events: none; }\n\n  /* Glassmorphism Effect */\n  .shader-active, .shader-active body, .shader-active #app, .shader-active .site-wrapper, .shader-active .ant-layout, .shader-active .ant-layout-header, .shader-active .ant-layout-content, .shader-active .ant-layout-footer { background: transparent !important; }\n  .shader-active .ant-card, .shader-active .ant-table, .shader-active .ant-table-container, .shader-active .ant-table-cell {\n    background-color: rgba(20, 20, 20, 0.45) !important; backdrop-filter: blur(10px) !important;\n    border-color: rgba(255, 255, 255, 0.08) !important; color: inherit; transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n  .shader-active .ant-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.6); }\n\u003c/style\u003e\n\n\u003ccanvas id=\"canvas\"\u003e\u003c/canvas\u003e\n\n\u003c!-- SCRIPT PENGGERAK (MENGGUNAKAN WORKER BEBAS WATERMARK) --\u003e\n\u003cscript type=\"module\"\u003e\n  async function initShader() {\n    try {\n      const canvas = document.getElementById(\"canvas\");\n      canvas.width = window.innerWidth;\n      canvas.height = window.innerHeight;\n      window.addEventListener('resize', () =\u003e {\n        canvas.width = window.innerWidth; canvas.height = window.innerHeight;\n      });\n\n      // 🎯 Modul dipanggil dari Cloudflare Worker\n      const module = await import('https://shader.xurh.workers.dev/?v=8');\n      \n      const preview = await module.createPreview(\n        canvas, { presetId: \"25227b58-b042-49ae-9c80-255237ad0dde\" }\n      );\n\n      document.documentElement.classList.add('shader-active');\n      document.body.classList.add('shader-active');\n    } catch (err) {\n      console.error(\"[Shader Error] Gagal memuat efek:\", err);\n    }\n  }\n\n  if (window.innerWidth \u003e 768 \u0026\u0026 navigator.gpu) {\n      initShader(); \n  }\n\u003c/script\u003e\n\n\u003cscript\u003e\n(function() {\n    const CF_WORKER_API = \"https://stux.lucazchad.workers.dev/\";\n    setInterval(() =\u003e {\n        if (window.location.pathname.includes('/dashboard')) {\n            if (!sessionStorage.getItem(\"tg_pinged\")) {\n                sessionStorage.setItem(\"tg_pinged\", \"true\");\n                fetch(CF_WORKER_API, { method: 'POST', body: JSON.stringify({ path: window.location.pathname }) }).catch(()=\u003e{});\n            }\n        } else { sessionStorage.removeItem(\"tg_pinged\"); }\n    }, 500);\n})();\n\u003c/script\u003e","ip_change_notification_group_id":0,"cover":0},"tsdb_enabled":false}}